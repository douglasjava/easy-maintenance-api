{
  "title": "Easy Maintenance — Overview",
  "uid": "easy-maintenance-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Taxa de Erros HTTP 5xx",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",application=\"easy-maintenance\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"easy-maintenance\"}[5m]))",
          "legendFormat": "Taxa 5xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Latência HTTP P95",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"easy-maintenance\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"easy-maintenance\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "JVM Heap Usage",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",application=\"easy-maintenance\"} / jvm_memory_max_bytes{area=\"heap\",application=\"easy-maintenance\"}",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "DB Connections (HikariCP)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"easy-maintenance\"} / hikaricp_connections_max{application=\"easy-maintenance\"}",
          "legendFormat": "Connections %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Assinaturas Ativas",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "easy_active_subscriptions{application=\"easy-maintenance\"}",
          "legendFormat": "Assinaturas",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Empresas Ativas",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "easy_organizations_active{application=\"easy-maintenance\"}",
          "legendFormat": "Empresas",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Usuários Ativos",
      "type": "stat",
      "gridPos": { "x": 20, "y": 8, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "easy_users_active{application=\"easy-maintenance\"}",
          "legendFormat": "Usuários",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Jobs — Tempo desde último sucesso (horas)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "(time() - easy_job_last_success_seconds{application=\"easy-maintenance\"}) / 3600",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 26 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Webhook DLQ — Eventos/hora",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(billing_webhook_dlq_count_total{application=\"easy-maintenance\"}[1h])",
          "legendFormat": "DLQ eventos/h",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
